{
  "name": "alrawi-client",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "tsx watch scripts/runtime/dev-server.mjs",
    "build": "vite build && esbuild server/_core/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "node scripts/runtime/start-server.mjs",
    "clean": "node scripts/runtime/clean-worktree.mjs",
    "check": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:push": "drizzle-kit generate && drizzle-kit migrate",
    "db:rebuild-local": "node scripts/database/rebuild-local-db.mjs",
    "db:generate-import-templates": "node scripts/imports/generate-system-import-templates.mjs",
    "db:reset-safe-production:dry-run": "node scripts/database/reset-safe-production-data.mjs",
    "db:reset-safe-production:apply": "node scripts/database/reset-safe-production-data.mjs --apply",
    "db:wipe-keep-schema:dry-run": "node scripts/database/wipe-production-keep-schema.mjs",
    "db:wipe-keep-schema:apply": "node scripts/database/wipe-production-keep-schema.mjs --apply",
    "db:migrate-old-trade-db:dry-run": "node scripts/imports/migrate-old-trade-db.mjs",
    "db:migrate-old-trade-db:apply": "node scripts/imports/migrate-old-trade-db.mjs --apply",
    "db:bootstrap-old-trade-import-db": "node scripts/imports/bootstrap-old-trade-import-db.mjs",
    "db:import-old-trade-json:dry-run": "node scripts/imports/import-old-trade-json.mjs",
    "db:import-old-trade-json:apply": "node scripts/imports/import-old-trade-json.mjs --apply",
    "db:sync-old-trade-import-to-production:dry-run": "node scripts/imports/sync-old-trade-import-to-production.mjs",
    "db:sync-old-trade-import-to-production:apply": "node scripts/imports/sync-old-trade-import-to-production.mjs --apply",
    "db:import-yaser-pdf:dry-run": "node scripts/imports/import-yaser-pdf.mjs",
    "db:import-yaser-pdf:apply": "node scripts/imports/import-yaser-pdf.mjs --apply",
    "db:import-real-workbook:dry-run": "node scripts/imports/import-real-workbook.mjs",
    "db:import-real-workbook:apply": "node scripts/imports/import-real-workbook.mjs --apply",
    "db:sync-real-workbook-operational:dry-run": "node scripts/imports/sync-real-workbook-operational.mjs",
    "db:sync-real-workbook-operational:apply": "node scripts/imports/sync-real-workbook-operational.mjs --apply"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@trpc/client": "^11.16.0",
    "@trpc/server": "^11.16.0",
    "axios": "^1.12.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cookie": "^1.0.2",
    "dotenv": "^17.2.2",
    "drizzle-orm": "^0.44.5",
    "express": "^4.21.2",
    "file-saver": "^2.0.5",
    "jose": "6.1.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.453.0",
    "mysql2": "^3.15.0",
    "nanoid": "^5.1.5",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-hook-form": "^7.64.0",
    "streamdown": "^1.4.0",
    "superjson": "^1.13.3",
    "tailwind-merge": "^3.3.1",
    "xlsx": "^0.18.5",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.1.3",
    "@types/express": "4.17.21",
    "@types/google.maps": "^3.58.1",
    "@types/node": "^24.7.0",
    "@types/react": "^19.2.1",
    "@types/react-dom": "^19.2.1",
    "@vitejs/plugin-react": "^5.0.4",
    "drizzle-kit": "^0.31.4",
    "esbuild": "^0.25.0",
    "pnpm": "^10.15.1",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.19.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3",
    "vite": "^7.1.7",
    "vitest": "^2.1.4"
  },
  "packageManager": "pnpm@10.4.1+sha512.c753b6c3ad7afa13af388fa6d808035a008e30ea9993f58c6663e2bc5ff21679aa834db094987129aa4d488b86df57f7b634981b2f827cdcacc698cc0cfb88af",
  "pnpm": {
    "overrides": {
      "tailwindcss>nanoid": "3.3.7"
    }
  }
}
