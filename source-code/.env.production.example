NODE_ENV=production
HOST=0.0.0.0
PORT=3000
TRUST_PROXY=1
API_BODY_LIMIT=10mb

# Required
JWT_SECRET=replace-with-a-random-secret-at-least-32-characters-long
DATABASE_URL=mysql://username:password@db-host:3306/database_name

# Optional in password-only deployments
VITE_APP_ID=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# Optional only if maps/storage proxy features are enabled
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
